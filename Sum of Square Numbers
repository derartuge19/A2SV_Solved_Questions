import math
class Solution(object):
    def judgeSquareSum(self, c):
        l = 0
        r = int(sqrt(c))

        while l <= r:
            summ = (l**2) + (r**2)
           
            if summ == c:
                return True
            elif summ < c:
                l += 1
            else:
                r -= 1
        return False
