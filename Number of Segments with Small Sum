n , k = map(int, input().split())
arr = list(map(int, input().split()))

count = 0
l = 0 
r = 0
curr_sum = 0 


while r < n:
    curr_sum += arr[r]
    
    while curr_sum > k:
        curr_sum -= arr[l]
        l += 1
        
    count += (r-l+1)
    
    r += 1    

print(count)        
    
    
