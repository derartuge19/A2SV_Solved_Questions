from collections import Counter

test = int(input())

for _ in range(test):
    s = input()
    t = input()

    count_s = Counter(s)
    count_t = Counter(t)
    
    flag = False
    for char, count in count_s.items():
        if count_t[char] < count:
            print("Impossible")
            flag = True
            break
    if flag:
        continue

    # Get extra characters (t minus s)
    extra_chars = []
    remaining_t = count_t - count_s
    for char in sorted(remaining_t.keys()):
        extra_chars.extend([char] * remaining_t[char])
    
    res = []
    s_idx = 0
    e_idx = 0
    
    while s_idx < len(s) and e_idx < len(extra_chars):
        if extra_chars[e_idx] < s[s_idx]:
            res.append(extra_chars[e_idx])
            e_idx += 1
        else:
            res.append(s[s_idx])
            s_idx += 1
    
    res.extend(s[s_idx:])
    res.extend(extra_chars[e_idx:])
    
    print("".join(res))
