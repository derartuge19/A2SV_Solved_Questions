from collections import defaultdict, deque

class Solution(object):
    def minimumTime(self, n, relations, time):
        """
        :type n: int
        :type relations: List[List[int]]
        :type time: List[int]
        :rtype: int
        """
        # Build graph and in-degrees
        graph = defaultdict(list)
        in_degree = [0] * (n + 1)
        
        for u, v in relations:
            graph[u].append(v)
            in_degree[v] += 1
            
        # Initialize queue and max_time array
        queue = deque()
        # dist[i] stores the max time needed to complete course i (1-indexed)
        dist = [0] * (n + 1)
        
        for i in range(1, n + 1):
            if in_degree[i] == 0:
                queue.append(i)
                dist[i] = time[i - 1]
                
        # Process graph using Kahn's algorithm
        while queue:
            curr = queue.popleft()
            
            for neighbor in graph[curr]:
                # Update the maximum completion time for the neighbor
                dist[neighbor] = max(dist[neighbor], dist[curr] + time[neighbor - 1])
                in_degree[neighbor] -= 1
                
                if in_degree[neighbor] == 0:
                    queue.append(neighbor)
                    
        return max(dist)
