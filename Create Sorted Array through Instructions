class Solution(object):
    def createSortedArray(self, instructions):
        """
        :type instructions: List[int]
        :rtype: int
        """
        m = max(instructions)
        # The BIT array stores frequencies of numbers
        bit = [0] * (m + 1)
        
        def update(i):
            while i <= m:
                bit[i] += 1
                i += i & (-i)
                
        def query(i):
            s = 0
            while i > 0:
                s += bit[i]
                i -= i & (-i)
            return s
        
        total_cost = 0
        MOD = 10**9 + 7
        
        for i, x in enumerate(instructions):
            # Count elements strictly less than x
            less_than = query(x - 1)
            # Count elements strictly greater than x
            # 'i' is the total number of elements already inserted
            greater_than = i - query(x)
            
            total_cost += min(less_than, greater_than)
            update(x)
            
        return total_cost % MOD
