class Solution(object):
    def wordBreak(self, s, wordDict):
        wordSet = set(wordDict)
        memo = {}

        def backtrack(index):
            if index == len(s):
                return [""]
            if index in memo:
                return memo[index]
            
            res = []
            for end in range(index + 1, len(s) + 1):
                word = s[index:end]
                if word in wordSet:
                    sub_sentences = backtrack(end)
                    for sub in sub_sentences:
                        res.append(word + (" " + sub if sub else ""))
            
            memo[index] = res
            return res

        return backtrack(0)
