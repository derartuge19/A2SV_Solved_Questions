class Solution(object):
    def subarraySum(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        count = 0
        current_sum = 0
        
        prefix_counts = {0: 1}
        
        for num in nums:
            current_sum += num
            
            diff = current_sum - k
            if diff in prefix_counts:
                count += prefix_counts[diff]
            
            prefix_counts[current_sum] = prefix_counts.get(current_sum, 0) + 1
            
        return count
