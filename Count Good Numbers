class Solution(object):
    def countGoodNumbers(self, n):
        MOD = 10**9 + 7
        
        def power(base, exp):
            if exp == 0:
                return 1
            
            half = power(base, exp // 2)
            res = (half * half) % MOD
            
            if exp % 2 == 1:
                res = (res * base) % MOD
            return res

        even_pos = (n + 1) // 2
        odd_pos = n // 2
        
        return (power(5, even_pos) * power(4, odd_pos)) % MOD
