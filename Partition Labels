class Solution(object):
    def partitionLabels(self, s):
        """
        :type s: str
        :rtype: List[int]
        """
        last_occurrence = {}
        for i, char in enumerate(s):
            last_occurrence[char] = i

        l = 0
        r = 0
        res = []

        for i , ch in enumerate(s):
            r = max(r ,last_occurrence[ch])

            if i == r:
                res.append(r-l+1)
                l = i + 1

        return res         

      
