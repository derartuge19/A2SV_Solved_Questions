test = int(input())

for i in range(test):
    strr = input()
    working_keys = set()
    
    n = len(strr)
    l = 0
    
    while l < n:
        if l + 1 == n or strr[l] != strr[l + 1]:
            working_keys.add(strr[l])
            l += 1
        else:
            l += 2
   
    res_list = list(working_keys)
    res_list.sort()
    print("".join(res_list))
