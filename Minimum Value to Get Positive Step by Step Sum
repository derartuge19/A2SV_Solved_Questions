class Solution(object):
    def minStartValue(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        min_sum = 0
        current_sum = 0
        
        for num in nums:
            current_sum += num
            min_sum = min(min_sum, current_sum)
         
        return 1 - min_sum
