class Solution(object):
    def splitString(self, s):
        """
        :type s: str
        :rtype: bool
        """
        def backtrack(index, prev_val):
            if index == len(s):
                return True
            
            for j in range(index + 1, len(s) + 1):
                val = int(s[index:j])
   
                if val == prev_val - 1:
                    if backtrack(j, val):
                        return True
                
            
            return False

     
        for i in range(1, len(s)):
            if backtrack(i, int(s[:i])):
                return True
                
        return False

